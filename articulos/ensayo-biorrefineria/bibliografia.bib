  file = {C\:\\Users\\mjlam\\Zotero\\storage\\23I8XKU3\\sc2c00921_si_001.pdf;C\:\\Users\\mjlam\\Zotero\\storage\\HQEAPVA4\\MacHin Ferrero and Mele - 2022 - Optimal Design of Sugar-Cane-Based Biorefinery Networks in Argentina.pdf}
