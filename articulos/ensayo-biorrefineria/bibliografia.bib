@incollection{cavalcante2015,
  title = {The {{Sugar Production Process}}},
  booktitle = {Sugarcane: {{Agricultural Production}}, {{Bioenergy}} and {{Ethanol}}},
  author = {Cavalcante, Claudio Soares and {de Albuquerque}, Fernando Medeiros},
  year = 2015,
  month = may,
  pages = {285--310},
  publisher = {Elsevier Inc.},
  urldate = {2025-04-07},
  abstract = {Sugar production with high standards of quality and a good yield is the goal of all sugar mills. To obtain excellent product quality with minimal losses, it is extremely important to know the quality of raw material which affects the sugar manufacturing process and the quality of the final product, thus hindering the attainment of productivity and profitability targets. A good broth treatment also ensures good sugar quality and minimal losses. Another important step is the "granagem" (crystallization) for complete sowing and it is extremely important to use good quality seed. The seed of the preparation to the conditions it will be used in seeding should be well cared for, prevented the formation of conglomerates or twin. Another important step is the crystallization of sucrose and driving from cooks. "Spinning" is one of the most important steps in the manufacturing process of the sugar and the results that can be obtained with proper operation are more important than is normally considered. Good projects with correct sizing of equipment and facilities, good automation and standardization in operational procedures of the production process are critical and have great influence on the quality of sugar produced. In addition to all these precautions, it is necessary that the centrifuges and the facilities until the sugar is packed, are all correct and well maintained. Centrifuges, conveyor belts, sugar dryers, hoppers and the environment can contribute and affect the quality of the already processed sugar.},
  isbn = {978-0-12-802239-9},
  keywords = {AREA:Agricola,AREA:Fabricacion,GEO:Brasil,MET:ML,SEC:Azucar,SEC:Bioetanol,SEC:Biomasa,TECH:BI,TECH:Control},
  annotation = {Citas\_GS: 2\\
Afiliacion: Universidade Federal de Alagoas\\
Abram, J.C., and J.T. Ramscan. 1978. Sugar cane processing., Hugot, E. 1986. Handbook of cane sugar engineering., Lichts, F.O. 2011. International sugar and sweetener report., Payne, J. H. 1982. Operation of raw sugar factories., Rein, P. W. 1995. A comparison of various juice extraction systems.},
  file = {C:\Users\mjlam\Zotero\storage\NWIEBTGY\cavalcante2015.pdf}
}

@phdthesis{ceconello2021,
  title = {{La mecanizaci\'on agr\'icola: cambios e innovaciones en los sistemas de cosecha de ca\~na de az\'ucar en Tucum\'an (1960 -- 2005). Un estudio sociot\'ecnico}},
  author = {Ceconello, Marcos},
  year = 2021,
  month = aug,
  urldate = {2025-04-08},
  abstract = {El moderno complejo agroazucarero de Tucum\'an cuenta con m\'as de 150 a\~nos de existencia, y, desde sus inicios, represent\'o una de las industrias m\'as importantes del interior de la Argentina. Al representar uno de los motores del desarrollo regional, adem\'as de su aporte econ\'omico a las finanzas provinciales, la cantidad de empleo generado, los v\'inculos entre los integrantes del sector agr\'icola y el industrial, las diversas innovaciones tecnol\'ogicas incorporadas en esta agroindustria fueron abordadas por numerosos estudios. Empero, en su mayor\'ia adjudicaron una relaci\'on lineal entre oferta y demanda de tecnolog\'ia, o bien analizaron el componente tecnol\'ogico de manera tangencial y accesoria. Con el prop\'osito de presentar un panorama m\'as integrador sobre las relaciones entre tecnolog\'ia y sociedad y aportar conocimiento a un \'area de vacancia, la investigaci\'on analiza el proceso de cambio e innovaci\'on en los sistemas de cosecha de ca\~na de az\'ucar empleados en Tucum\'an, entre 1960 y 2005. La elecci\'on de la actividad de cosecha no resulta azarosa, en tanto esta fase del ciclo productivo azucarero requiere la mayor cantidad de mano de obra y de recursos econ\'omicos, adem\'as de representar el nexo fundamental entre campo y f\'abrica, con un alto nivel de incidencia en el resultado final de las zafras. El enfoque te\'orico seleccionado, propio del \'area de los estudios sociot\'ecnicos, obedeci\'o a la necesidad de superar los an\'alisis parciales de los procesos de innovaci\'on tecnol\'ogica, dar cuenta de las diferentes variables que intervinieron en la configuraci\'on de los distintos escenarios productivos, y las alternativas tecnol\'ogicas encontradas para superarlos. La metodolog\'ia empleada combin\'o las t\'ecnicas del an\'alisis documental con las entrevistas en profundidad, y permiti\'o interpretar el complejo fen\'omeno de las innovaciones tecnol\'ogicas y su relaci\'on con los factores sociales. Los resultados mostraron que las modificaciones ocurridas en la cosecha de ca\~na distaron de constituir una serie de etapas graduales y evolutivas. Tampoco existi\'o, t\'ecnicamente, un sistema de cosecha m\'as eficiente que otro. Cada uno tuvo su propia l\'ogica de organizaci\'on y los motivos de su reemplazo excedieron las dimensiones t\'ecnicas, para abarcar factores sociales y econ\'omicos que se vincularon con los aspectos agr\'icolas propios del cultivo. En conclusi\'on, eludiendo las posiciones dicot\'omicas entre tecnolog\'ia y sociedad, se pudo demostrar que los cambios tecnol\'ogicos a lo largo del per\'iodo analizado estuvieron influidos por variables de diversa \'indole y disputas en torno a su significado por parte de actores sociales que los adoptaron.},
  langid = {spanish},
  school = {Instituto Nacional de Tecnolog\'ia Agropecuaria},
  keywords = {AREA:Agricola,GEO:Argentina,GEO:Brasil,I4.0:IoT,MET:ML,SEC:Azucar,TECH:BI},
  annotation = {Citas\_GS: 14\\
Afiliacion: Universidad Nacional de Quilmes\\
Bijker, W. 1995. Of Bicycles, Bakelites and Bulbs. Toward a Theory of Sociotechnical Change., Braverman, H. 1974. Trabajo y capital monopolista. La degradaci\'on del trabajo en el siglo XX., Flichy, P. 1995. L'innovation technique. R\'ecents d\'eveloppements en sciences sociales. Vers une nouvelle th\'eorie de l'innovation., Giarracca, N.; S. Aparicio y C. Gras. 2003. Contratistas, chacareros y pueblos. Racionalidad y conflictos en la pampa gringa., Thomas, H. y A. Buch. 2008. Actos, actores y artefactos. Sociolog\'ia de la tecnolog\'ia.},
  file = {C:\Users\mjlam\Zotero\storage\DURLQCL4\Ceconello Marcos Mauricio - 2021 - La mecanización agrícola cambios e innovaciones en los sistemas de cosecha de caña de azúcar en Tuc.pdf}
}

