@phdthesis{gutti2016,
  title = {{{LA DIFUSI\'ON DE LAS INNOVACIONES EN LAS CADENAS DE VALOR BASADAS EN PROCESOS BIOL\'OGICOS}}: {{EL CASO DE LA CA\~NA DE AZ\'UCAR EN TUCUM\'AN}}, {{ARGENTINA}}},
