  shorttitle = {Finding the Sweet Spot in {{Industry}} 4.0 Transformation},
  author = {Sureeyatanapas, Panitas and Pancharoen, Danai and Saengprachatanarug, Khwantri},
  year = 2024,
  month = nov,
  journal = {Benchmarking: An International Journal},
  volume = {31},
