@article{schmitz2017,
  title = {Sugarcane {{Yields}} and {{Production}}: {{Florida}} and {{Louisiana}}},
  shorttitle = {Sugarcane {{Yields}} and {{Production}}},
  author = {Schmitz, Andrew and Kennedy, P. Lynn and Salassi, Michael},
  year = 2017,
  journal = {Frontiers of Economics and Globalization},
  volume = {17},
  pages = {143--157},
  publisher = {Emerald Group Publishing Limited},
  doi = {10.1108/S1574-871520170000017010},
  urldate = {2026-02-25},
  abstract = {In this chapter the development of new sugarcane varieties in Florida and Louisiana is examined, along with the accompanying advancement in mechanization technology through the widespread adoption of sugarcane harvesters. An econometric analysis is carried out to determine the impact of the price of raw sugar on raw-sugar yields in Louisiana and Florida. This study found that in the case of Louisiana, the 3-year lagged US raw-sugar price had a positive and significant impact on sugar yields. The change in raw-sugar prices did not have a significant impact on sugar yields for the Florida industry. Sugar production has increased over time, in part, due to the development of new sugarcane varieties accompanied by modern sugarcane harvesters. Given the relationship between price and yield, particularly in Louisiana, policy makers and producers must be mindful of the potential impact of policy-induced research and development (R\&D) on the competitiveness of their industry.},
  langid = {english},
  keywords = {/unread,AREA:Agricola,AREA:Fabricacion,AREA:Gestion,Herbicides,MET:Competitividad,MET:ML,pesticides,Q01,SEC:Azucar,sugarcane,TECH:BI,technology,varieties},
