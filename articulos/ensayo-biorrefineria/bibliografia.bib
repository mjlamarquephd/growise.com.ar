}

@article{teixeira2023,
  title = {A Review of Mathematical Optimization Models Applied to the Sugarcane Supply Chain},
  author = {Teixeira, Eduardo dos Santos and Rangel, Socorro and Florentino, Helenice de O. and {de Araujo}, Silvio Alexandre},
  year = 2023,
  month = jul,
  journal = {International Transactions in Operational Research},
  volume = {30},
  number = {4},
  pages = {1755--1788},
  issn = {1475-3995},
  doi = {10.1111/itor.13056},
  urldate = {2025-12-12},
  abstract = {Sugarcane is a product of great economic relevance and, as well as its use for the production of different types of sugar, it is also a renewable source for the production of bio-fuels, other bio-products, and electricity. In this context, efficient planning and technology changes are necessary to ensure high productivity, competitiveness and harmony with economic, social, and environmental issues. Consequently, this sector needs technical and scientific support. Mathematical optimization models can be useful to build efficient planning tools for the activities involved in the sugarcane supply chain, helping to address these challenges. This paper describes the sugarcane supply chain and presents a literature review of mathematical optimization models that have been proposed to represent its main stages: planting, harvesting, transporting, industrial processing, and marketing. The findings show that several models have been proposed to represent these five stages, however, most of them have not been thoroughly explored from the point of view of strength of the models and solution methods. Moreover, the harvesting stage is the one that has received more attention than the other stages. In the integration of two or more stages, there are many challenges yet to be addressed by mathematical optimization models. This review contributes to a better understanding of the sugar-energy sector and opens up new perspectives for future investigations.},
  copyright = {\copyright{} 2021 The Authors. International Transactions in Operational Research \copyright{} 2021 International Federation of Operational Research Societies},
  langid = {english},
  keywords = {AREA:Agricola,AREA:Fabricacion,GEO:Brasil,MET:BPM,MET:Competitividad,MET:ML,MET:Modelado,MET:Optimizacion,Review,SEC:Azucar,SEC:Bioeconomia,TECH:BI,TECH:Simulacion},
  annotation = {Citas\_GS: 0\\
Afiliacion: Universidade Federal Fluminense\\
Higgins, A. J., \& Muchow, R. C. (2003)},
  file = {C:\Users\mjlam\Zotero\storage\HMNR3VFW\Teixeira et al. - 2023 - A review of mathematical optimization models applied to the sugarcane supply chain.pdf}
}

@phdthesis{tekin2018,
  title = {Competitive Intelligence Analytics for Operations Managers},
  author = {Tekin, M{\"u}ge},
  year = 2018,
